{
  "name": "protondb-mcp",
  "version": "2026.6.6",
  "description": "MCP server for fetching and analyzing ProtonDB Linux/Proton game compatibility reports",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "protondb-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "ingest": "node dist/scripts/ingest.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspector": "pnpm build && npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.8.1",
    "stream-json": "^1.9.1",
    "tar": "^7.4.3",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/stream-json": "^1.7.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.0.0"
  }
}
