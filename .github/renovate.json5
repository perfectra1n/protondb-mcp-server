{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // Use the community "home-operations" shareable Renovate config.
  extends: [
    "github>home-operations/renovate-config",
  ],
  timezone: "America/New_York",
  // Assign/review on the maintainer.
  assignees: ["perfectra1n"],
  reviewers: ["perfectra1n"],
  // The CI cron (renovate.yaml) controls *when* Renovate runs (daily, morning);
  // this keeps PR creation aligned with that window too.
  schedule: ["* 6-10 * * *"],
  packageRules: [
    {
      description: "Group MCP SDK + zod together",
      matchManagers: ["npm"],
      matchPackageNames: ["@modelcontextprotocol/sdk", "zod"],
      groupName: "mcp sdk",
    },
    {
      description: "Keep the playwright npm package and Docker base image in lockstep",
      matchPackageNames: ["playwright", "mcr.microsoft.com/playwright"],
      groupName: "playwright",
    },
  ],
}
